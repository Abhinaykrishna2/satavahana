# Satavahana — Zerodha Market Data Pipeline Configuration
# Copy this file to config.toml and fill in your credentials.

[kite]
# From your Kite Connect app at https://developers.kite.trade
api_key    = "your_api_key_here"
api_secret = "your_api_secret_here"

# Leave access_token EMPTY (or remove the line) to trigger the automated
# OAuth login flow on startup — browser opens, you log in, token is captured
# automatically and cached in .kite_token for the rest of the trading day.
#
# Only fill this manually if you want to bypass the login flow.
access_token = ""

[equities]
# Symbols to watch on both NSE and BSE for spread arbitrage
symbols = ["INFY", "TCS", "RELIANCE", "HDFCBANK", "ICICIBANK", "SBIN", "ITC", "LT", "WIPRO", "TATASTEEL"]

[options]
# Underlying indices for options chain.
# Supported: NIFTY, NIFTYNXT50, FINNIFTY (and any single-stock NFO name).
# MIDCPNIFTY omitted: options are illiquid with wide bid-ask spreads.
underlyings = ["NIFTY"]
# Leave empty for AUTO mode (nearest available expiry selected per underlying).
# Optional manual override: set to a specific YYYY-MM-DD.
expiry = ""
# Strike range [min, max] — must cover ALL configured underlyings.
# FINNIFTY ~24000, NIFTY ~25000, NIFTYNXT50 ~27000.
# Set min=0 / max=999999 to include all available strikes (recommended).
strike_min = 0.0
strike_max = 999999.0
# Strike step size (used only for display/logging; filtering is by strike_min/max)
strike_step = 50.0
# Global default: keep only the N nearest strikes per underlying on EACH side of ATM.
# 15 each side = 32 contracts per underlying (2 ATM + 15 CE + 15 PE).
# Applies to NIFTY and NIFTYNXT50 (most liquid — use more strikes for chain-level OI coverage).
# Total tokens: NIFTY(32) + NIFTYNXT50(32) + FINNIFTY(12) + 3 index = 79 — well within 3000.
nearest_strikes = 15
# Per-underlying override: FINNIFTY data quality is lower (illiquid OTM strikes, zero-LTP rows).
# Restrict to 5 each side to keep only the liquid near-ATM zone.
[options.nearest_strikes_override]
FINNIFTY = 5

[greeks]
# Risk-free rate (annualized, decimal). 6.5% for Indian markets
risk_free_rate = 0.065
# Dividend yield (annualized, decimal). Set to 0 if unknown
dividend_yield = 0.0

[output]
# Minimum spread in rupees to log (noise filter)
min_spread_alert = 0.50
# Log frequency for options greeks (every N ticks)
greeks_log_interval = 1

# ─── NSE Options Signal Engine ───────────────────────────────────────────────
# Capital path: ₹5,000 → ₹50,000 via 6 quant strategies
# All fields have safe defaults — this block is OPTIONAL in config.toml
[options_engine]
# Your starting trading capital in INR
initial_capital = 10000.0

# Daily circuit-breaker: halt all new positions if loss exceeds this % today
# 30% = stop trading once day's loss > ₹1,500 on ₹5,000 capital
max_daily_loss_pct = 30.0

# Profit target on option premium (% gain from entry price)
# 55% = if you bought at ₹100, exit when option reaches ₹155
profit_target_pct = 55.0

# Stop-loss on option premium (% loss from entry price)
# 35% = if you bought at ₹100, exit when option falls to ₹65
stop_loss_pct = 35.0

# Minimum composite confidence score (0-100) to act on a signal.
# Each strategy scores sub-signals; composite must clear this bar.
# 58 = balanced. Raise to 65+ for fewer, higher-quality signals.
min_confidence = 58.0

# How often to run the full chain scan (seconds)
# 45 = scan every 45s during market hours
scan_interval_secs = 45

# Max total entries per IST trading day (across all underlyings)
# 1 = take the first qualifying signal of the day and stop. If it stops out,
# no further entries — avoids compounding losses on volatile days.
max_daily_trades = 1

[execution]
# Set true only when you want live broker order placement enabled.
enable_live_orders = false

# Kite order parameters for options execution.
variety = "regular"
exchange = "NFO"
product = "MIS"
order_type = "MARKET"
validity = "DAY"

# Prefix used in Kite order tag for place/cancel/status correlation.
order_tag_prefix = "SATA"

# Cancel unfilled limit entry orders after this many seconds (default: 240 = 4 minutes).
entry_order_timeout_secs = 240

# Cancel pending entry if the option LTP drops this fraction below the limit price.
# A large drop means the market reversed direction — no point filling a stale signal.
# Default 0.15 = cancel if LTP < limit_price × 0.85 (15% adverse move).
limit_cancel_reversal_pct = 0.15
